NODE_ENV=development
# Cloud example: https://your-project-id.supabase.co
# Local example: http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Shared secret for scheduled recurring materialization endpoint
SUBSCRIPTION_MATERIALIZATION_CRON_SECRET=change-me-with-a-long-random-secret

# Observability alerts (beta internal)
# 1 to enable rule-based alerts, 0 to disable
OBS_ALERTS_ENABLED=0
# Incoming webhook URL (Slack/Discord/Teams compatible JSON endpoint)
OBS_ALERT_WEBHOOK_URL=
# Optional secondary webhook used only for alerting health signals/probes
OBS_ALERT_HEALTH_WEBHOOK_URL=
# Environment label displayed in alerts (e.g. beta-internal)
OBS_ALERT_ENV=development
# Cooldown between repeated alerts for same rule
OBS_ALERT_COOLDOWN_MS=300000
# Cooldown between repeated alerting-health signals
OBS_ALERT_HEALTH_COOLDOWN_MS=600000
# Behavior when distributed alert-state backend is unavailable:
# - local: fallback to in-memory dedupe/cooldown (degraded multi-instance guarantees)
# - drop: suppress dispatch until backend recovers
OBS_ALERT_DEDUPE_FAILURE_MODE=local

# In beta environments (OBS_ALERT_ENV=beta-*), alerts are mandatory:
# - OBS_ALERTS_ENABLED must be 1
# - OBS_ALERT_WEBHOOK_URL must be set
# - SUPABASE_SERVICE_ROLE_KEY must be present (distributed dedupe backend)

# Distributed rate limit fallback policy
# Auth-sensitive actions: deny|local (recommended: deny)
RATE_LIMIT_AUTH_DISTRIBUTED_FAILURE_MODE=deny
# Data mutations: deny|local|allow (recommended: local)
RATE_LIMIT_MUTATION_DISTRIBUTED_FAILURE_MODE=local
# Fallback for unspecified/non-critical operations
RATE_LIMIT_DEFAULT_DISTRIBUTED_FAILURE_MODE=local
# Retry window returned when fail-closed is applied
RATE_LIMIT_FAIL_CLOSED_RETRY_MS=60000
